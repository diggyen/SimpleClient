# Minimal Linux kernel configuration for rdpboot kiosk.
# Designed for QEMU + real x86_64 hardware with framebuffer and evdev support.

CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y
CONFIG_NR_CPUS=8

# ── Core ──────────────────────────────────────────────────────────────────────
CONFIG_PRINTK=y
CONFIG_PANIC_ON_OOPS=y
CONFIG_HZ_250=y
CONFIG_POSIX_TIMERS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ── Networking ────────────────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_TCP_CONG_CUBIC=y
CONFIG_NET_CORE=y
CONFIG_NETDEVICES=y
CONFIG_ETHERNET=y
CONFIG_E1000=y
CONFIG_E1000E=y
CONFIG_VIRTIO_NET=y
CONFIG_VMXNET3=y

# ── Block / SCSI ──────────────────────────────────────────────────────────────
CONFIG_BLOCK=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_ISO9660_FS=y
CONFIG_UDF_FS=y
CONFIG_INITRAMFS_SOURCE=""

# ── Framebuffer ──────────────────────────────────────────────────────────────
CONFIG_FB=y
CONFIG_FB_VESA=y
CONFIG_FB_EFI=y
CONFIG_FB_SIMPLE=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_VGA_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE=n
# CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY is not set
# Disable cursor blinking (kiosk).
CONFIG_LOGO=n

# ── Input ─────────────────────────────────────────────────────────────────────
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_INPUT_MOUSE=y
CONFIG_MOUSE_PS2=y
CONFIG_MOUSE_PS2_ALPS=y
CONFIG_INPUT_MISC=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y

# ── Virtualisation ────────────────────────────────────────────────────────────
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=n
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y

# ── Security: disable dangerous features ─────────────────────────────────────
CONFIG_SYSRQ=n
CONFIG_MAGIC_SYSRQ=n
CONFIG_KEXEC=n
CONFIG_PROC_KCORE=n
CONFIG_MODULES=n
CONFIG_STACK_VALIDATION=n
CONFIG_UNWINDER_GUESS=y
# CONFIG_UNWINDER_FRAME_POINTER is not set

# ── Compression ───────────────────────────────────────────────────────────────
CONFIG_KERNEL_GZIP=y
CONFIG_RD_GZIP=y
